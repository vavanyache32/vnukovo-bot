{
  "title": "vnukovo-bot",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Time since last METAR",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "time_since_last_metar_seconds"}]
    },
    {
      "type": "stat",
      "title": "Time since last NWS pull",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "time_since_last_nws_seconds"}]
    },
    {
      "type": "timeseries",
      "title": "Source success rate",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "rate(source_success_total[5m])", "legendFormat": "{{source}} ok"},
        {"expr": "rate(source_failure_total[5m])", "legendFormat": "{{source}} err"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Poll latency p95",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, rate(poll_latency_seconds_bucket[5m]))", "legendFormat": "{{source}}"}]
    },
    {
      "type": "timeseries",
      "title": "Info vs resolve disagreement (°C)",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "targets": [{"expr": "info_vs_resolve_disagreement_celsius"}]
    },
    {
      "type": "timeseries",
      "title": "Notifications by severity",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 8},
      "targets": [{"expr": "rate(notifications_sent_total[5m])", "legendFormat": "{{severity}}"}]
    },
    {
      "type": "stat",
      "title": "Proxy health",
      "gridPos": {"x": 0, "y": 36, "w": 12, "h": 4},
      "targets": [{"expr": "proxy_health", "legendFormat": "{{name}}"}]
    },
    {
      "type": "timeseries",
      "title": "Forecast edge by bucket",
      "gridPos": {"x": 0, "y": 40, "w": 12, "h": 8},
      "targets": [{"expr": "forecast_edge", "legendFormat": "{{bucket}}"}]
    }
  ]
}
