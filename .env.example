# =================== Events / station ===================
DEFAULT_CITY=moscow
EVENT_DISCOVERY_ENABLED=true
EVENT_SLUG_PATTERNS=highest-temperature-in-moscow-on-*
RESOLUTION_TIMEZONE=Europe/Moscow

# =================== Polling ============================
POLL_INTERVAL_SECONDS=25
POLL_JITTER_SECONDS=5
DELTA_NOTIFY_THRESHOLD_C=0.5
NEAR_BOUNDARY_LOWER_C=0.4
NEAR_BOUNDARY_UPPER_C=0.6

# =================== Storage ============================
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# =================== Telegram ===========================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# =================== Proxies (per-host) =================
# Любой пустой = direct
PROXY_TELEGRAM=
PROXY_TELEGRAM_FALLBACK=
PROXY_POLYMARKET=
PROXY_AVIATION=
PROXY_DEFAULT=
DOH_RESOLVER=https://1.1.1.1/dns-query

# =================== API tokens =========================
SYNOPTIC_TOKEN=
AVWX_TOKEN=
CHECKWX_TOKEN=
WUNDERGROUND_API_KEY=

# =================== Observability ======================
SENTRY_DSN=
PROMETHEUS_ENABLED=true
HEALTH_PORT=8080
LOG_LEVEL=INFO
LOG_JSON=true
